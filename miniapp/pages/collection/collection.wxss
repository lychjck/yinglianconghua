.collection-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #f7f2ea 0%, #f0e8d8 100%);
}

.page-header {
  padding: 100rpx 48rpx 32rpx;
  text-align: center;
}

.page-title {
  font-size: 36rpx;
  color: #2c2418;
  letter-spacing: 12rpx;
}

.page-count {
  font-size: 22rpx;
  color: #8a7e6c;
  letter-spacing: 2rpx;
  margin-top: 8rpx;
}

/* 列表 */
.collection-list {
  flex: 1;
  padding: 0 32rpx 160rpx;
}

.collection-card {
  background: rgba(255,255,255,0.5);
  border: 1rpx solid rgba(184,150,62,0.12);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.collection-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #d4b86a, transparent);
}

/* 删除按钮 */
.card-delete {
  position: absolute;
  top: 24rpx;
  right: 32rpx;
  font-size: 32rpx;
  color: rgba(138,126,108,0.4);
  padding: 8rpx;
  line-height: 1;
}

/* 对联文本 */
.card-couplet {
  text-align: center;
  margin-bottom: 20rpx;
}

.card-line {
  font-size: 32rpx;
  color: #2c2418;
  letter-spacing: 4rpx;
  line-height: 2;
  display: block;
}

.card-divider {
  width: 60rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #b8963e, transparent);
  margin: 12rpx auto;
}

/* 作者 + 标签行 */
.card-meta-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.card-author {
  font-size: 24rpx;
  color: #5a4e3c;
  letter-spacing: 2rpx;
}

.card-tag {
  font-size: 18rpx;
  color: #b8963e;
  border: 1rpx solid rgba(184,150,62,0.35);
  border-radius: 12rpx;
  padding: 2rpx 12rpx;
}

/* 出处 */
.card-source {
  text-align: center;
  font-size: 22rpx;
  color: #8a7e6c;
  letter-spacing: 2rpx;
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-bottom: 200rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #5a4e3c;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8a7e6c;
  letter-spacing: 2rpx;
}
