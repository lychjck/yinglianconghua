.search-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background:
    radial-gradient(ellipse at 30% 20%, rgba(184,150,62,0.06) 0%, transparent 60%),
    radial-gradient(ellipse at 70% 80%, rgba(139,37,0,0.04) 0%, transparent 60%),
    linear-gradient(180deg, #f7f2ea 0%, #f0e8d8 50%, #ede3cf 100%);
}

/* ===== 搜索栏 ===== */
.search-bar {
  display: flex;
  align-items: center;
  padding: 100rpx 32rpx 24rpx;
  gap: 20rpx;
}

.search-input-wrap {
  flex: 1;
  background: rgba(255,255,255,0.6);
  border: 1rpx solid rgba(184,150,62,0.2);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
}

.search-input {
  font-size: 28rpx;
  color: #2c2418;
  letter-spacing: 2rpx;
  width: 100%;
}

.search-placeholder {
  color: #b0a590;
  letter-spacing: 2rpx;
}

.search-cancel {
  font-size: 28rpx;
  color: #5a4e3c;
  letter-spacing: 2rpx;
  white-space: nowrap;
}

/* ===== 筛选栏 ===== */
.filter-bar {
  padding: 0 32rpx 24rpx;
  display: flex;
  gap: 16rpx;
}

.filter-group {
  flex: 1;
  min-width: 0;
}

.filter-select {
  width: 100%;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  color: #5a4e3c;
  background: rgba(255,255,255,0.6);
  border: 1rpx solid rgba(184,150,62,0.2);
  border-radius: 16rpx;
  letter-spacing: 2rpx;
  text-align: center;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* ===== 结果统计 ===== */
.result-stats {
  padding: 0 40rpx 16rpx;
  font-size: 22rpx;
  color: #8a7e6c;
  letter-spacing: 2rpx;
}

.result-count {
  color: #b8963e;
}

/* ===== 结果列表 ===== */
.search-list {
  flex: 1;
  padding: 0 32rpx;
}

/* ===== 对联卡片（复用 browse 样式） ===== */
.browse-card {
  background: rgba(255,255,255,0.5);
  border: 1rpx solid rgba(184,150,62,0.12);
  border-radius: 24rpx;
  padding: 32rpx 40rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.browse-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #d4b86a, transparent);
}

.browse-card-couplet {
  text-align: center;
  margin-bottom: 20rpx;
}

.browse-card-line {
  font-size: 30rpx;
  color: #2c2418;
  letter-spacing: 4rpx;
  line-height: 1.8;
  display: block;
}

.browse-card-divider {
  width: 60rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #b8963e, transparent);
  margin: 8rpx auto;
}

.browse-card-meta {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.browse-card-author {
  font-size: 24rpx;
  color: #5a4e3c;
  letter-spacing: 2rpx;
}

.browse-card-tags {
  display: flex;
  gap: 8rpx;
}

.browse-card-tag {
  font-size: 18rpx;
  color: #b8963e;
  border: 1rpx solid rgba(184,150,62,0.35);
  border-radius: 12rpx;
  padding: 2rpx 12rpx;
  letter-spacing: 1rpx;
}

/* ===== 高亮文本 ===== */
.highlight {
  color: #b8963e;
}

/* ===== 加载更多 ===== */
.load-more {
  text-align: center;
  padding: 32rpx 0 160rpx;
  font-size: 24rpx;
  color: #8a7e6c;
  letter-spacing: 4rpx;
}

.load-more-dot {
  display: inline;
  animation: dotPulse 1.2s infinite;
}

.dot-1 { animation-delay: 0s; }
.dot-2 { animation-delay: 0.2s; }
.dot-3 { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 80%, 100% { opacity: 0.3; }
  40% { opacity: 1; }
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #8a7e6c;
  letter-spacing: 4rpx;
}

/* ===== 加载中 ===== */
.loading-indicator {
  text-align: center;
  padding: 120rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #8a7e6c;
  letter-spacing: 4rpx;
}
