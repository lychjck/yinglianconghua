<view class="search-page">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <input
        class="search-input"
        type="text"
        confirm-type="search"
        placeholder="搜索对联、作者…"
        placeholder-class="search-placeholder"
        value="{{keyword}}"
        bindinput="onInputChange"
        bindconfirm="onSearch"
        focus="true"
      />
    </view>
    <view class="search-cancel" bindtap="onCancel">取消</view>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-bar" wx:if="{{searched}}">
    <picker class="filter-group" mode="selector" range="{{dynasties}}" value="{{dynastyIndex}}" bindchange="onDynastyChange">
      <view class="filter-select">{{dynasties[dynastyIndex] || '全部朝代'}}</view>
    </picker>
    <picker class="filter-group" mode="selector" range="{{occasions}}" value="{{occasionIndex}}" bindchange="onOccasionChange">
      <view class="filter-select">{{occasions[occasionIndex] || '全部场合'}}</view>
    </picker>
    <picker class="filter-group" mode="selector" range="{{books}}" value="{{bookIndex}}" bindchange="onBookChange">
      <view class="filter-select">{{books[bookIndex] || '全部书籍'}}</view>
    </picker>
  </view>

  <!-- 结果统计 -->
  <view class="result-stats" wx:if="{{searched && total > 0}}">
    <text>共 <text class="result-count">{{total}}</text> 副</text>
  </view>

  <!-- 结果列表 -->
  <view class="search-list" wx:if="{{couplets.length > 0}}">
    <view
      class="browse-card"
      wx:for="{{couplets}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goDetail"
    >
      <view class="browse-card-couplet">
        <view class="browse-card-line">
          <text wx:for="{{item.firstSegments}}" wx:for-item="seg" wx:key="index" class="{{seg.highlight ? 'highlight' : ''}}">{{seg.text}}</text>
        </view>
        <view class="browse-card-divider"></view>
        <view class="browse-card-line">
          <text wx:for="{{item.secondSegments}}" wx:for-item="seg" wx:key="index" class="{{seg.highlight ? 'highlight' : ''}}">{{seg.text}}</text>
        </view>
      </view>
      <view class="browse-card-meta">
        <view class="browse-card-author" wx:if="{{item.author}}">
          <text wx:for="{{item.authorSegments}}" wx:for-item="seg" wx:key="index" class="{{seg.highlight ? 'highlight' : ''}}">{{seg.text}}</text>
        </view>
        <view class="browse-card-tags">
          <text class="browse-card-tag" wx:if="{{item.dynasty}}">{{item.dynasty}}</text>
          <text class="browse-card-tag" wx:if="{{item.occasion}}">{{item.occasion}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载更多 / 已加载全部 -->
  <view class="load-more" wx:if="{{couplets.length > 0}}">
    <block wx:if="{{!allLoaded}}">
      <text class="load-more-dot dot-1">·</text>
      <text class="load-more-dot dot-2">·</text>
      <text class="load-more-dot dot-3">·</text>
      <text> 上拉加载更多</text>
    </block>
    <text wx:else>已加载全部</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{searched && !loading && couplets.length === 0}}">
    <text class="empty-text">未找到相关对联</text>
  </view>

  <!-- 加载中 -->
  <view class="loading-indicator" wx:if="{{loading && couplets.length === 0}}">
    <text class="loading-text">搜索中...</text>
  </view>
</view>
