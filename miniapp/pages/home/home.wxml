<view class="home-page">
  <!-- 顶部标题 -->
  <view class="home-header">
    <view class="app-title">对联雅集</view>
    <view class="app-subtitle">楹 联 丛 话</view>
  </view>

  <!-- 对联展示区 -->
  <view class="couplet-area" bindtap="fetchRandom">
    <view class="couplet-display" wx:if="{{couplet}}">
      <!-- 下联（左） -->
      <view class="couplet-column">
        <text
          wx:for="{{secondChars}}"
          wx:key="index"
          class="couplet-char {{animating ? 'char-animate' : ''}}"
          style="animation-delay: {{0.6 + index * 0.08}}s"
        >{{item}}</text>
      </view>
      <!-- 上联（右） -->
      <view class="couplet-column">
        <text
          wx:for="{{firstChars}}"
          wx:key="index"
          class="couplet-char {{animating ? 'char-animate' : ''}}"
          style="animation-delay: {{index * 0.08}}s"
        >{{item}}</text>
      </view>
    </view>
    <view class="loading-text" wx:if="{{loading}}">载入中...</view>
  </view>

  <!-- 作者/来源 -->
  <view class="couplet-author" wx:if="{{couplet}}" bindtap="goDetail">
    <text class="author-text">— {{couplet.source.String || '楹联丛话'}} —</text>
    <view class="author-hint" wx:if="{{couplet.ref}}">点击查看出处 ›</view>
  </view>

  <!-- 操作提示 -->
  <view class="hint-area">
    <view class="hint-icon">↻</view>
    <view class="hint-text">点击空白处换一副</view>
  </view>
</view>

<!-- 浮动按钮层（在 home-page 外面，确保不被 flex 布局影响） -->
<view class="float-buttons" wx:if="{{couplet}}">
  <view class="seal-btn" catchtap="saveFavorite">
    <image 
      class="seal-img {{isFavorited ? 'seal-active' : ''}}" 
      src="/images/seal-collect.png"
      mode="aspectFit"
    />
  </view>
  <view class="share-btn" catchtap="showShareSheet">
    <text class="share-icon">分享</text>
  </view>
</view>

<!-- 分享弹窗 -->
<view class="share-mask" wx:if="{{showShare}}" catchtap="hideShareSheet">
  <view class="share-panel" catchtap="">
    <view class="share-title">分享此联</view>
    <view class="share-options">
      <button class="share-option" open-type="share">
        <text class="share-opt-icon">💬</text>
        <text class="share-opt-label">发给好友</text>
      </button>
      <view class="share-option" catchtap="saveAsImage">
        <text class="share-opt-icon">🖼</text>
        <text class="share-opt-label">保存图片</text>
      </view>
      <view class="share-option" catchtap="saveServerImage">
        <text class="share-opt-icon">🎨</text>
        <text class="share-opt-label">生成图片</text>
      </view>
      <view class="share-option" catchtap="copyCouplet">
        <text class="share-opt-icon">📋</text>
        <text class="share-opt-label">复制文字</text>
      </view>
    </view>
    <view class="share-cancel" catchtap="hideShareSheet">取消</view>
  </view>
</view>

<!-- 图片预览弹窗 -->
<view class="preview-mask" wx:if="{{showPreview}}" catchtap="hidePreview">
  <view class="preview-panel" catchtap="">
    <view class="preview-card">
      <canvas type="2d" id="shareCanvas" class="share-canvas"
        style="width:{{canvasW}}px;height:{{canvasH}}px;"></canvas>
    </view>
    <view class="preview-actions">
      <view class="preview-btn" catchtap="doSaveImage">保存到相册</view>
      <view class="preview-btn preview-btn-cancel" catchtap="hidePreview">取消</view>
    </view>
  </view>
</view>
