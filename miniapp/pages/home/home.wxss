.home-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background:
    radial-gradient(ellipse at 30% 20%, rgba(184,150,62,0.06) 0%, transparent 60%),
    radial-gradient(ellipse at 70% 80%, rgba(139,37,0,0.04) 0%, transparent 60%),
    linear-gradient(180deg, #f7f2ea 0%, #f0e8d8 50%, #ede3cf 100%);
}

/* 顶部 */
.home-header {
  padding: 100rpx 0 40rpx;
  text-align: center;
}

.home-header::after {
  content: '';
  display: block;
  width: 240rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #b8963e, transparent);
  margin: 32rpx auto 0;
}

.app-title {
  font-size: 44rpx;
  color: #2c2418;
  letter-spacing: 16rpx;
}

.app-subtitle {
  font-size: 24rpx;
  color: #8a7e6c;
  letter-spacing: 8rpx;
  margin-top: 12rpx;
}

/* 对联展示区 */
.couplet-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 80rpx;
  position: relative;
  min-height: 600rpx;
}

/* 两列并排：下联在左，上联在右（传统从右往左读） */
.couplet-display {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: flex-start;
  gap: 100rpx;
}

/* 每列：纵向排列每个字 */
.couplet-column {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.couplet-char {
  display: block;
  font-size: 56rpx;
  color: #2c2418;
  line-height: 1;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.03);
  opacity: 0;
}

.couplet-char.char-animate {
  animation: charReveal 0.4s ease-out forwards;
}

@keyframes charReveal {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.loading-text {
  font-size: 28rpx;
  color: #8a7e6c;
  letter-spacing: 4rpx;
}

/* 作者信息 */
.couplet-author {
  text-align: center;
  padding: 0 80rpx 20rpx;
}

.author-text {
  font-size: 26rpx;
  color: #8a7e6c;
  letter-spacing: 4rpx;
}

.author-hint {
  font-size: 22rpx;
  color: #b8963e;
  letter-spacing: 2rpx;
  margin-top: 8rpx;
}

/* 操作提示 */
.hint-area {
  text-align: center;
  padding-bottom: 40rpx;
}

.hint-icon {
  display: inline-block;
  width: 40rpx;
  height: 40rpx;
  border: 1rpx solid rgba(138,126,108,0.3);
  border-radius: 50%;
  line-height: 38rpx;
  font-size: 20rpx;
  color: #8a7e6c;
  margin-bottom: 8rpx;
}

.hint-text {
  font-size: 22rpx;
  color: #8a7e6c;
  letter-spacing: 4rpx;
  opacity: 0.6;
}

/* 收藏印章 */
.seal-btn {
  position: fixed;
  right: 56rpx;
  top: 200rpx;
  z-index: 10;
}

.seal-img {
  width: 88rpx;
  height: 88rpx;
  opacity: 0.35;
  transition: opacity 0.3s;
  mix-blend-mode: multiply;
}

.seal-img.seal-active {
  opacity: 0.9;
}
