.home-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background:
    radial-gradient(ellipse at 30% 20%, rgba(184,150,62,0.06) 0%, transparent 60%),
    radial-gradient(ellipse at 70% 80%, rgba(139,37,0,0.04) 0%, transparent 60%),
    linear-gradient(180deg, #f7f2ea 0%, #f0e8d8 50%, #ede3cf 100%);
}

.home-header {
  padding: 100rpx 0 40rpx;
  text-align: center;
}

.home-header::after {
  content: '';
  display: block;
  width: 240rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #b8963e, transparent);
  margin: 32rpx auto 0;
}

.app-title {
  font-size: 44rpx;
  color: #2c2418;
  letter-spacing: 16rpx;
}

.app-subtitle {
  font-size: 24rpx;
  color: #8a7e6c;
  letter-spacing: 8rpx;
  margin-top: 12rpx;
}

.couplet-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 80rpx;
  min-height: 600rpx;
}

.couplet-display {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: flex-start;
  gap: 100rpx;
}

.couplet-column {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.couplet-char {
  display: block;
  font-size: 56rpx;
  color: #2c2418;
  line-height: 1;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.03);
  opacity: 0;
}

.couplet-char.char-animate {
  animation: charReveal 0.4s ease-out forwards;
}

@keyframes charReveal {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.loading-text {
  font-size: 28rpx;
  color: #8a7e6c;
  letter-spacing: 4rpx;
}

.couplet-author {
  text-align: center;
  padding: 0 80rpx 20rpx;
}

.author-text {
  font-size: 26rpx;
  color: #8a7e6c;
  letter-spacing: 4rpx;
}

.author-hint {
  font-size: 22rpx;
  color: #b8963e;
  letter-spacing: 2rpx;
  margin-top: 8rpx;
}

.hint-area {
  text-align: center;
  padding-bottom: 40rpx;
}

.hint-icon {
  display: inline-block;
  width: 40rpx;
  height: 40rpx;
  border: 1rpx solid rgba(138,126,108,0.3);
  border-radius: 50%;
  line-height: 38rpx;
  font-size: 20rpx;
  color: #8a7e6c;
  margin-bottom: 8rpx;
}

.hint-text {
  font-size: 22rpx;
  color: #8a7e6c;
  letter-spacing: 4rpx;
  opacity: 0.6;
}

/* ===== 浮动按钮层 ===== */
.float-buttons {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 100;
}

.seal-btn {
  position: absolute;
  right: 40rpx;
  top: 200rpx;
  pointer-events: auto;
  padding: 16rpx;
}

.seal-img {
  width: 88rpx;
  height: 88rpx;
  opacity: 0.35;
  transition: opacity 0.3s;
  mix-blend-mode: multiply;
}

.seal-img.seal-active {
  opacity: 0.9;
}

.share-btn {
  position: absolute;
  left: 40rpx;
  top: 208rpx;
  pointer-events: auto;
  padding: 16rpx;
}

.share-icon {
  font-size: 24rpx;
  color: #8a7e6c;
  letter-spacing: 4rpx;
  border: 1rpx solid rgba(138,126,108,0.3);
  border-radius: 24rpx;
  padding: 8rpx 20rpx;
  display: inline-block;
}

/* ===== 分享弹窗 ===== */
.share-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.share-panel {
  width: 100%;
  background: #f7f2ea;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx 40rpx 60rpx;
}

.share-title {
  text-align: center;
  font-size: 30rpx;
  color: #2c2418;
  letter-spacing: 6rpx;
  margin-bottom: 40rpx;
}

.share-options {
  display: flex;
  justify-content: center;
  gap: 60rpx;
  margin-bottom: 40rpx;
}

.share-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.share-option::after {
  border: none;
}

.share-opt-icon {
  font-size: 48rpx;
  width: 96rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: rgba(255,255,255,0.6);
  border-radius: 50%;
  border: 1rpx solid rgba(184,150,62,0.15);
}

.share-opt-label {
  font-size: 22rpx;
  color: #5a4e3c;
  letter-spacing: 2rpx;
}

.share-cancel {
  text-align: center;
  font-size: 28rpx;
  color: #8a7e6c;
  letter-spacing: 4rpx;
  padding: 20rpx;
  border-top: 1rpx solid rgba(184,150,62,0.15);
}

/* ===== 图片预览弹窗 ===== */
.preview-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.7);
  z-index: 1001;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.preview-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  width: 85vw;
}

.preview-card {
  display: flex;
  justify-content: center;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.4);
}

.share-canvas {
  display: block;
  border-radius: 12rpx;
}

.preview-actions {
  display: flex;
  gap: 24rpx;
}

.preview-btn {
  background: rgba(255,255,255,0.95);
  color: #2c2418;
  font-size: 28rpx;
  letter-spacing: 4rpx;
  padding: 18rpx 56rpx;
  border-radius: 36rpx;
}

.preview-btn-cancel {
  background: rgba(255,255,255,0.3);
  color: #fff;
}
